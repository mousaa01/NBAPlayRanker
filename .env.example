# Copy this file to .env and fill in the values.
#   cp .env.example .env        (macOS / Linux)
#   copy .env.example .env      (Windows)

# ── Backend (Python / FastAPI) ──────────────────────────────────
# Supabase JWT secret – find it in your Supabase dashboard under
# Settings > API > JWT Settings > JWT Secret.
SUPABASE_JWT_SECRET=

# Supabase project URL – used to fetch JWKS public keys for ES256 tokens.
SUPABASE_URL=

# ── Frontend (Next.js) ──────────────────────────────────────────
# Base URL of the running backend API.
NEXT_PUBLIC_API_BASE=http://localhost:8000

# Supabase project credentials (Settings > API > Project API keys).
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=
